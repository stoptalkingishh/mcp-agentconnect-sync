# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Test / tooling
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Local runtime state (shared memory DB, artifacts). Never commit these.
data/
*.sqlite
*.sqlite3
*.db

# Secrets. NEVER commit real secrets — only the *.example.yaml templates.
config/secrets.yaml
config/secrets.local.yaml
.env
*.pem
*.key

# Machine-specific MCP client registration (absolute venv paths) — generated by
# deploy/register_mcp.py, never portable across machines.
.mcp.json

# Editor
.idea/
.vscode/
*.swp
